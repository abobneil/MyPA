{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LLM Memory Manifest",
  "type": "object",
  "required": ["schema_version", "scope", "created_by", "updated_at"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "scope": {
      "type": "string",
      "enum": ["project", "global"]
    },
    "created_by": {
      "type": "string"
    },
    "updated_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    }
  },
  "additionalProperties": true
}
