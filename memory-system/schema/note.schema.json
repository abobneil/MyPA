{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LLM Memory Note",
  "type": "object",
  "required": [
    "id",
    "title",
    "kind",
    "scope",
    "status",
    "priority",
    "audience",
    "updated_at",
    "tags",
    "summary"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "enum": ["context", "preference", "workflow", "decision", "session", "inbox"]
    },
    "scope": {
      "type": "string",
      "enum": ["base", "global", "project"]
    },
    "status": {
      "type": "string",
      "enum": ["canonical", "draft", "raw"]
    },
    "priority": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "audience": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "updated_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true
}
